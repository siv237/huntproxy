#!/usr/bin/env python3
"""setproxy — local cascading proxy with transparent mode + web dashboard."""

import argparse
import asyncio
import logging
import os
import signal
import sys
import time
import yaml
from pathlib import Path

from manager import ProxyManager
from server import ProxyServer

PROJECT_DIR = Path(__file__).resolve().parent
CONFIG_PATH = PROJECT_DIR / "config.yaml"
DATA_DIR = PROJECT_DIR / "data"

logger = logging.getLogger("setproxy")


def load_config() -> dict:
    if not CONFIG_PATH.exists():
        print(f"ERROR: {CONFIG_PATH} not found", file=sys.stderr)
        sys.exit(1)
    with open(CONFIG_PATH) as f:
        return yaml.safe_load(f)


def build_manager_and_server(config: dict):
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    manager = ProxyManager(str(DATA_DIR), config.get("proxies", {}))
    server = ProxyServer(config.get("server", {}), manager)
    return manager, server


async def cmd_start(args):
    config = load_config()
    manager, server = build_manager_and_server(config)
    await manager.start()
    proxy_task = asyncio.create_task(server.start())

    loop = asyncio.get_event_loop()
    stop = asyncio.Event()
    for sig in (signal.SIGINT, signal.SIGTERM):
        loop.add_signal_handler(sig, stop.set)

    print("=" * 56)
    print("setproxy running.")
    print(f"  Web:         http://127.0.0.1:{server.web_port}/")
    print(f"  HTTP proxy:  127.0.0.1:{server.http_port}")
    print(f"  SOCKS5:      127.0.0.1:{server.socks5_port}")
    if server.transparent_enabled:
        print(f"  Transparent: 127.0.0.1:{server.transp_port}")
    print("=" * 56)
    print("Press Ctrl+C to stop.")

    try:
        await stop.wait()
    except KeyboardInterrupt:
        pass

    print("\nShutting down...")
    await server.stop()
    await manager.stop()
    if not proxy_task.done():
        proxy_task.cancel()


async def cmd_status(args):
    config = load_config()
    manager, _ = build_manager_and_server(config)
    s = manager.get_status()
    print(f"Pool: {s['pool_total']} total, {s['pool_alive']} alive, "
          f"{s['pool_dead']} dead, {s['blacklisted']} blacklisted")
    print(f"Strategy: {s['strategy']}")
    if s['active_proxy']:
        ap = s['active_proxy']
        print(f"Active:   {ap['address']} ({ap['country']}, {ap['protocol']})")
    else:
        print("Active:   (none — pool empty)")


async def cmd_list(args):
    config = load_config()
    manager, _ = build_manager_and_server(config)
    s = manager.get_status()
    print(f"Pool: {s['pool_total']} total, {s['pool_alive']} alive\n")
    rows = await manager.list_proxies(args.count)
    if not rows:
        print("(empty)")
        return
    print(f"{'Address':<22} {'Proto':<8} {'Country':<18} {'Latency':<8} {'Fails'}")
    for r in rows:
        print(f"{r['address']:<22} {r['protocol']:<8} {r['country']:<18} "
              f"{r['latency']:<8} {r['failures']}")


async def cmd_blacklist(args):
    config = load_config()
    manager, _ = build_manager_and_server(config)

    if args.add:
        await manager.blacklist_add(args.add, args.reason or "")
        print(f"Blacklisted: {args.add}")
    elif args.remove:
        await manager.blacklist_remove(args.remove)
        print(f"Removed from blacklist: {args.remove}")
    else:
        print(f"Blacklist ({len(manager.blacklist)} entries):")
        for addr, reason in sorted(manager.blacklist.items()):
            print(f"  {addr:<22} {reason}")


async def cmd_refresh(args):
    config = load_config()
    manager, _ = build_manager_and_server(config)
    print("Refreshing proxy pool... (this may take 1-3 minutes)")
    start = time.time()
    await manager.force_refresh()
    elapsed = time.time() - start
    s = manager.get_status()
    print(f"Done in {elapsed:.1f}s. Pool: {s['pool_total']} total, {s['pool_alive']} alive")


def main():
    p = argparse.ArgumentParser(
        description="setproxy — local cascading proxy with transparent mode")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("start", help="Start proxy server + manager (foreground)").set_defaults(
        func=lambda args: cmd_start(args))

    sp_status = sub.add_parser("status", help="Show pool status")
    sp_status.set_defaults(func=cmd_status)

    sp_list = sub.add_parser("list", help="List working proxies")
    sp_list.add_argument("-n", "--count", type=int, default=20)
    sp_list.set_defaults(func=cmd_list)

    sp_bl = sub.add_parser("blacklist", help="Manage blacklist")
    sp_bl.add_argument("--add", metavar="IP:PORT")
    sp_bl.add_argument("--remove", metavar="IP:PORT")
    sp_bl.add_argument("--reason", metavar="REASON")
    sp_bl.set_defaults(func=cmd_blacklist)

    sp_refresh = sub.add_parser("refresh", help="Force refresh of proxy pool")
    sp_refresh.set_defaults(func=cmd_refresh)

    args = p.parse_args()
    try:
        asyncio.run(args.func(args))
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
